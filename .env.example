# ============================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your real values.
# The .env file is git-ignored and must NEVER be committed.
# ============================================================

# Primary admin account
ADMIN_EMAIL=your_admin@email.com
ADMIN_PASSWORD=YourStrongPassword123!
ADMIN_NAME=System Admin

# Secondary admin accounts (RBAC roles)
SUPER_ADMIN_EMAIL=super_admin@yourcompany.com
SUPER_ADMIN_PASSWORD=YourSuperAdminPassword!

FINANCE_ADMIN_EMAIL=finance_admin@yourcompany.com
FINANCE_ADMIN_PASSWORD=YourFinanceAdminPassword!

PROJECT_ADMIN_EMAIL=project_admin@yourcompany.com
PROJECT_ADMIN_PASSWORD=YourProjectAdminPassword!

SECURITY_ADMIN_EMAIL=security_admin@yourcompany.com
SECURITY_ADMIN_PASSWORD=YourSecurityAdminPassword!

# JWT signing secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Server ports
PORT_PUBLIC_API=3003
PORT_ADMIN_API=3004

# Debug OTP — set to false in production!
DEBUG_OTP=false
