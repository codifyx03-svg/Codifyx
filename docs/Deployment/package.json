{
  "name": "devforce-india",
  "version": "1.0.0",
  "description": "Full-stack client, worker, and admin marketplace platform for part-time developers",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend:build": "npm --prefix apps/react-frontend run build",
    "frontend:dev": "npm --prefix apps/react-frontend run dev",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:backend": "gcloud run deploy devforce-backend --source . --platform managed --allow-unauthenticated",
    "test": "node tests/test_flow.js",
    "test:auth": "node tests/test_auth.js",
    "test:payment": "node tests/test_payment_system.js",
    "test:payout": "node tests/test_payout_flow.js",
    "test:team": "node tests/test_team_flow.js",
    "test:security": "node tests/test_admin_security.js",
    "db:reset": "node scripts/reset-db.js",
    "admin:unlock": "node scripts/unlock-admin.js"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.1.0",
    "form-data": "^4.0.6",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "nodemon": "^3.1.14",
    "sqlite3": "^5.1.7"
  },
  "engines": {
    "node": "20"
  }
}
