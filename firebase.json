{
  "hosting": [
    {
      "site": "codifyx-solutions",
      "public": "apps/client-web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    },
    {
      "site": "codifyx-solutions-worker",
      "public": "apps/worker-web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/",
          "destination": "/login.html"
        },
        {
          "source": "/index.html",
          "destination": "/login.html"
        }
      ]
    },
    {
      "site": "codifyx-solutions-admin",
      "public": "apps/admin-web",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/",
          "destination": "/portal-entry-secure-x97.html"
        },
        {
          "source": "/index.html",
          "destination": "/portal-entry-secure-x97.html"
        }
      ]
    }
  ]
}
